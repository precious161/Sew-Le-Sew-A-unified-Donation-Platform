# Root .gitignore
cat > .gitignore << 'EOF'
# Environment files (NEVER commit)
.env
.env.local
.env.production
.env.*.local

# Dependencies
node_modules/
*/node_modules/
frontend/node_modules/
backend/node_modules/

# Build outputs
dist/
build/
frontend/dist/
backend/dist/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database
*.db
*.sqlite
*.sqlite-journal
prisma/*.db

# IDE
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Docker
*.pid
docker-compose.override.yml

# Coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp

# Deployment
.vercel/
.render/
EOF