generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// User Management Subsystem
// ─────────────────────────────────────────

enum Role {
  Red_Cross_Admin
  Donor
  Recipient
}

enum Status {
  Active
  Deactivated
}

// NEW: Identity Verification Status
enum IdentityStatus {
  Unverified
  Pending
  Verified
  Rejected
}

model User {
  id            String   @id @default(uuid())
  FirstName     String
  LastName      String
  EmailAddress  String   @unique
  Password      String
  PhoneNumber   String?
  Role          Role     @default(Donor)
  status        Status   @default(Active)
  bloodType     String?


  identityStatus          IdentityStatus @default(Unverified)
  identityDocumentUrl     String?        // Cloudinary URL for National ID
  identityVerifiedAt      DateTime?
  identityVerifiedBy      String?
  identityRejectionReason String?


  createdAt     DateTime @default(now())

  // Relations
  notification           Notification[]
  eligibilityLogs        EligibilityLog[]
  eligibilityStatuses    UserEligibilityStatus[]
  donationIntents        DonationIntent[]
  healthInfo             HealthInformation?
  requests               DonationRequest[]
  confirmedMatches       Match[]                 @relation("MatchConfirmer")
  financialContributions FinancialContribution[]
  allocatedContributions FinancialContribution[] @relation("FinancialAllocator")
  verifiedRequests       DonationRequest[]       @relation("RequestVerifier")
  verifiedContributions  FinancialContribution[] @relation("FinancialVerifier")


  verifiedIdentities     User[]                  @relation("IdentityVerifier")
  identityVerifierAdmin  User?                   @relation("IdentityVerifier", fields: [identityVerifiedBy], references: [id])
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────
// Donation Management Subsystem
// ─────────────────────────────────────────

enum Category {
  Blood
  Organ
  Financial
  In_Kind
}

enum RuleDataType {
  Number
  Boolean
  String
}

model MedicalStandard {
  id          String       @id @default(uuid())
  category    Category
  ruleKey     String
  dataType    RuleDataType
  value       String
  description String?
  updatedAt   DateTime     @updatedAt

  @@unique([category, ruleKey])
}

model EligibilityLog {
  id         String   @id @default(uuid())
  userId     String
  category   Category
  answers    Json
  isEligible Boolean
  reasonCode String?
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

enum EligibilityStatus {
  Eligible
  Ineligible
  NotChecked
}

model UserEligibilityStatus {
  userId          String
  category        Category
  status          EligibilityStatus @default(Ineligible)
  ineligibleUntil DateTime?
  lastCheckedAt   DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@id([userId, category])
}

enum IntentStatus {
  Active
  Matched
  Completed
  Cancelled
}

model DonationIntent {
  id          String       @id @default(uuid())
  userId      String
  category    Category
  location    String       @default("Red Cross Center, Addis Ababa")
  plannedDate DateTime
  status      IntentStatus @default(Active)

  // In-Kind specific fields
  itemType    String?
  quantity    Int?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  matches Match[]
}

enum UrgencyLevel {
  Low
  Medium
  High
  Critical
}

enum RequestStatus {
  PendingVerification
  Pending
  Matching
  Fulfilled
  Cancelled
}

model HealthInformation {
  id                String   @id @default(uuid())
  userId            String   @unique
  bloodType         String
  weight            Float
  height            Float
  medicalConditions String?
  allergies         String?
  notes             String?
  lastUpdated       DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])
}

model DonationRequest {
  id                String        @id @default(uuid())
  recipientId       String
  donationType      Category
  requiredBloodType String?
  organType         String?
  quantity          Int           @default(1)
  urgencyLevel      UrgencyLevel  @default(Medium)
  status            RequestStatus @default(PendingVerification)
  notes             String?

  // In-Kind specific fields
  itemType          String?
  itemQuantity      Int?

  // Urgency verification fields
  hospitalName      String?
  attendingDoctor   String?
  documentUrl       String?

  // Admin verification fields
  verifiedBy        String?
  verifiedAt        DateTime?
  rejectionReason   String?
  originalUrgency   UrgencyLevel?

  requestDate       DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  user              User          @relation(fields: [recipientId], references: [id])
  verifiedByUser    User?         @relation("RequestVerifier", fields: [verifiedBy], references: [id])
  matches           Match[]
}

// ─────────────────────────────────────────
// AI and Matching Subsystem
// ─────────────────────────────────────────

enum MatchStatus {
  Pending
  Notified
  Accepted
  Declined
  Completed
  Cancelled
}

model Match {
  id          String      @id @default(uuid())
  intentId    String
  requestId   String
  confirmedBy String?
  status      MatchStatus @default(Pending)

  // Stage timestamps
  notifiedAt  DateTime?
  acceptedAt  DateTime?
  declinedAt  DateTime?
  completedAt DateTime?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  intent          DonationIntent  @relation(fields: [intentId], references: [id])
  request         DonationRequest @relation(fields: [requestId], references: [id])
  confirmedByUser User?           @relation("MatchConfirmer", fields: [confirmedBy], references: [id])

  @@unique([requestId, status])
}

enum FinancialStatus {
  Pending
  Verified
  Allocated
  Failed
}

model FinancialContribution {
  id             String          @id @default(uuid())
  donorId        String
  amount         Float
  currency       String          @default("ETB")
  purpose        String?
  status         FinancialStatus @default(Pending)

  // Document verification fields
  documentUrl      String?
  rejectionReason  String?
  verifiedBy       String?
  verifiedAt       DateTime?

  // Allocation fields
  allocatedBy    String?
  allocatedAt    DateTime?
  allocationNote String?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relations
  donor             User  @relation(fields: [donorId], references: [id])
  allocatedByUser   User? @relation("FinancialAllocator", fields: [allocatedBy], references: [id])
  verifiedByUser    User? @relation("FinancialVerifier", fields: [verifiedBy], references: [id])
}