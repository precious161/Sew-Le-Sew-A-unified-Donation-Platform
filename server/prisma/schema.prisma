generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum Role {
  Red_Cross_Admin
  Donor
  Recipient
}

enum Status {
  Active
  Deactivated
}

enum IdentityStatus {
  Unverified
  Pending
  Verified
  Rejected
}

enum Category {
  Blood
  Organ
  Financial
  In_Kind
}

enum RuleDataType {
  Number
  Boolean
  String
}

enum EligibilityStatus {
  Eligible
  Ineligible
  NotChecked
}

enum IntentStatus {
  PendingVerification
  Active
  Matched
  Completed
  Cancelled
}

enum UrgencyLevel {
  Low
  Medium
  High
  Critical
}

enum RequestStatus {
  PendingVerification
  Pending
  Matching
  Fulfilled
  Cancelled
}

enum MatchStatus {
  Pending
  Notified
  Accepted
  Declined
  Completed
  Cancelled
}

enum FinancialStatus {
  Pending
  Verified
  Allocated
  Failed
}

enum EventStatus {
  Active
  Cancelled
  Completed
}

// ─────────────────────────────────────────
// User Management Subsystem
// ─────────────────────────────────────────

model User {
  id            String         @id @default(uuid())
  FirstName     String
  LastName      String
  EmailAddress  String         @unique
  Password      String
  PhoneNumber   String?
  Role          Role           @default(Donor)
  status        Status         @default(Active)
  bloodType     String?
  createdAt     DateTime       @default(now())

  // Identity verification fields
  identityDocumentUrl     String?
  identityStatus          IdentityStatus @default(Unverified)
  identityVerifiedAt      DateTime?
  identityVerifiedBy      String?
  identityRejectionReason String?

  // Relations
  notification           Notification[]
  eligibilityLogs        EligibilityLog[]
  eligibilityStatuses    UserEligibilityStatus[]
  donationIntents        DonationIntent[]
  healthInfo             HealthInformation?
  requests               DonationRequest[]
  confirmedMatches       Match[]                 @relation("MatchConfirmer")
  financialContributions FinancialContribution[]
  allocatedContributions FinancialContribution[] @relation("FinancialAllocator")
  verifiedContributions  FinancialContribution[] @relation("FinancialVerifier")
  verifiedRequests       DonationRequest[]       @relation("RequestVerifier")
  verifiedIntents        DonationIntent[]        @relation("IntentVerifier")
  verifiedIdentities     User[]                  @relation("IdentityVerifier")
  identityVerifierAdmin  User?                   @relation("IdentityVerifier", fields: [identityVerifiedBy], references: [id])
  donationHistory        DonationHistory[]       @relation("DonorHistory")
  auditLogs              AuditLog[]              @relation("AdminAuditLogs")
  createdEvents          DonationEvent[]         @relation("EventCreator")
  attendingEvents        DonationEvent[]         @relation("EventAttendees")
  analyticsReports       AnalyticsReport[]       @relation("AnalyticsReportCreator")

  @@index([Role])
  @@index([status])
  @@index([identityStatus])
  @@index([createdAt])
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id           String   @id @default(uuid())
  adminId      String
  action       String   // e.g., "Approved donor-recipient match"
  targetEntity String   // e.g., "Match", "User", "DonationRequest"
  remarks      String?  // e.g., "Urgent request approved"
  createdAt    DateTime @default(now()) // Maps to ActionDate in your doc

  // Relations
  admin        User     @relation("AdminAuditLogs", fields: [adminId], references: [id])
}

// ─────────────────────────────────────────
// Donation Management Subsystem
// ─────────────────────────────────────────

model MedicalStandard {
  id          String       @id @default(uuid())
  category    Category
  ruleKey     String
  dataType    RuleDataType
  value       String
  description String?
  updatedAt   DateTime     @updatedAt

  @@unique([category, ruleKey])
}

model EligibilityLog {
  id         String   @id @default(uuid())
  userId     String
  category   Category
  answers    Json
  isEligible Boolean
  reasonCode String?
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

model UserEligibilityStatus {
  userId          String
  category        Category
  status          EligibilityStatus @default(Ineligible)
  ineligibleUntil DateTime?
  lastCheckedAt   DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@id([userId, category])
}

model DonationIntent {
  id          String       @id @default(uuid())
  userId      String
  category    Category
  location    String       @default("Red Cross Center, Addis Ababa")
  plannedDate DateTime
  status      IntentStatus @default(Active)

  // In-Kind specific fields
  itemType    String?
  quantity    Int?

  // Verification fields
  documentUrl     String?
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectionReason String?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  user           User    @relation(fields: [userId], references: [id])
  verifiedByUser User?   @relation("IntentVerifier", fields: [verifiedBy], references: [id])
  matches        Match[]
}

model HealthInformation {
  id                String   @id @default(uuid())
  userId            String   @unique
  bloodType         String
  weight            Float
  height            Float
  medicalConditions String?
  allergies         String?
  notes             String?
  lastUpdated       DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])
}

model DonationRequest {
  id                String        @id @default(uuid())
  recipientId       String
  donationType      Category
  requiredBloodType String?
  organType         String?
  quantity          Int           @default(1)
  urgencyLevel      UrgencyLevel  @default(Medium)
  status            RequestStatus @default(PendingVerification)
  notes             String?

  // In-Kind specific fields
  itemType          String?
  itemQuantity      Int?

  // Verification fields
  hospitalName      String?
  attendingDoctor   String?
  documentUrl       String?
  verifiedBy        String?
  verifiedAt        DateTime?
  rejectionReason   String?
  originalUrgency   UrgencyLevel?

  requestDate       DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  user           User          @relation(fields: [recipientId], references: [id])
  verifiedByUser User?         @relation("RequestVerifier", fields: [verifiedBy], references: [id])
  matches        Match[]
  @@index([status])
  @@index([donationType])
  @@index([urgencyLevel])
  @@index([recipientId, status])
}

model DonationHistory {
  id              String      @id @default(uuid())
  donorId         String
  donationDate    DateTime    @default(now())
  donationType    Category
  quantity        Int?
  location        String?
  complications   String?
  remarks         String?
  status          MatchStatus @default(Completed)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  donor           User        @relation("DonorHistory", fields: [donorId], references: [id])
  matchId         String?     @unique
  match           Match?      @relation(fields: [matchId], references: [id])
}

// ─────────────────────────────────────────
// Matching Subsystem
// ─────────────────────────────────────────

model Match {
  id          String      @id @default(uuid())
  intentId    String
  requestId   String
  confirmedBy String?
  status      MatchStatus @default(Pending)

  // Stage timestamps
  notifiedAt  DateTime?
  acceptedAt  DateTime?
  declinedAt  DateTime?
  completedAt DateTime?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  intent          DonationIntent  @relation(fields: [intentId], references: [id])
  request         DonationRequest @relation(fields: [requestId], references: [id])
  confirmedByUser User?           @relation("MatchConfirmer", fields: [confirmedBy], references: [id])

  @@unique([requestId, status])
donationHistory DonationHistory?
 @@index([intentId])
  @@index([requestId])
  @@index([status])
}


model FinancialContribution {
  id             String          @id @default(uuid())
  donorId        String
  amount         Float
  currency       String          @default("ETB")
  purpose        String?
  status         FinancialStatus @default(Pending)

  // Verification fields
  documentUrl     String?
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectionReason String?

  // Allocation fields
  allocatedBy    String?
  allocatedAt    DateTime?
  allocationNote String?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relations
  donor           User  @relation(fields: [donorId], references: [id])
  verifiedByUser  User? @relation("FinancialVerifier", fields: [verifiedBy], references: [id])
  allocatedByUser User? @relation("FinancialAllocator", fields: [allocatedBy], references: [id])
}

// ─────────────────────────────────────────
// Event Management Subsystem
// ─────────────────────────────────────────

model DonationEvent {
  id          String      @id @default(uuid())
  eventName   String
  description String?
  location    String      // Physical address/description
  latitude    Float?      // Map Coordinates
  longitude   Float?      // Map Coordinates

  eventDate   DateTime    // The day of the event
  startTime   String      // e.g., "09:00"
  endTime     String      // e.g., "17:00"

  status      EventStatus @default(Active)

  createdBy   String      // The Admin who created it
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  admin       User        @relation("EventCreator", fields: [createdBy], references: [id])
  attendees   User[]   @relation("EventAttendees")
  @@index([eventDate])
  @@index([status])
}

// ─────────────────────────────────────────
// AI ChatBot and Analytics Subsystem
// ─────────────────────────────────────────

model ChatInteraction {
  id             String   @id @default(uuid())
  userId         String
  query          String
  response       String
  interactionDate DateTime @default(now())
  status         String   @default("Answered")

  @@index([userId])
  @@index([interactionDate])
}

model AnalyticsReport {
  id            String   @id @default(uuid())
  reportType    String
  summary       String
  generatedDate DateTime @default(now())
  format        String
  createdBy     String?
  fileUrl       String?

  // Relation
  creator       User?    @relation("AnalyticsReportCreator", fields: [createdBy], references: [id])

  @@index([generatedDate])
  @@index([reportType])
  @@index([createdBy])
}