
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User Management Subsystem Tables

enum Role {
  Red_Cross_Admin
  Donor
  Recipient
}

enum Status {
  Active
  Deactivated
}

model User {
  id            String   @id @default(uuid())
  FirstName     String
  LastName      String
  EmailAddress  String   @unique
  Password      String
  PhoneNumber   String?
  Role          Role     @default(Donor)
  status        Status   @default(Active)
  bloodType     String?
  createdAt     DateTime @default(now())
  notification  Notification[]
  eligibilityLogs     EligibilityLog[]
  eligibilityStatuses UserEligibilityStatus[]
  donationIntents DonationIntent[]
  healthInfo HealthInformation?
  requests DonationRequest[]
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}


model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}


// Donation Management Subsystem Tables

enum Category{
   Blood
   Organ
   Financial
   In_Kind
}

enum RuleDataType{
  Number
  Boolean
  String
}

model MedicalStandard{
  id        String   @id @default(uuid())
  category  Category
  ruleKey   String
  dataType  RuleDataType
  value     String
  description String?
  updatedAt   DateTime   @updatedAt

  @@unique([category,ruleKey])
}


model EligibilityLog {
  id           String   @id @default(uuid())
  userId       String
  category     Category
  answers      Json
  isEligible   Boolean
  reasonCode   String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

enum EligibilityStatus {
  Eligible
  Ineligible
  NotChecked
}

model UserEligibilityStatus {
  userId          String
  category        Category
  status          EligibilityStatus @default(Ineligible)
  ineligibleUntil DateTime?

  lastCheckedAt   DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])
  @@id([userId, category])
}

enum IntentStatus {
  Active
  Matched
  Completed
  Cancelled
}

model DonationIntent {
  id            String       @id @default(uuid())
  userId        String
  category      Category

  location      String       @default("Red Cross Center, Addis Ababa")
  plannedDate   DateTime

  status        IntentStatus @default(Active)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User         @relation(fields: [userId], references: [id])


  @@unique([userId, category, status])
}

enum UrgencyLevel {
  Low
  Medium
  High
  Critical
}

enum RequestStatus {
  Pending
  Matching
  Fulfilled
  Cancelled
}

model HealthInformation {
  id                String   @id @default(uuid())
  userId            String   @unique
  bloodType         String
  weight            Float
  height            Float
  medicalConditions String?
  allergies         String?
  notes             String?

  lastUpdated       DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
}


model DonationRequest {
  id                String        @id @default(uuid())
  recipientId       String
  donationType      Category
  requiredBloodType String?
  organType         String?
  quantity          Int           @default(1)
  urgencyLevel      UrgencyLevel  @default(Medium)
  status            RequestStatus @default(Pending)
  notes             String?

  requestDate       DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User          @relation(fields: [recipientId], references: [id])
}