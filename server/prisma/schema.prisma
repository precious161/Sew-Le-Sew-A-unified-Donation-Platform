
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DONOR
  RECIPIENT
}

enum Status {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model User {
  id            String   @id @default(uuid())
  FristName     String
  LastName      String
  EmailAddress  String   @unique
  password      String
  phoneNumber   String?
  role          Role     @default(DONOR)
  status        Status   @default(ACTIVE)
  createdAt     DateTime @default(now())

}
